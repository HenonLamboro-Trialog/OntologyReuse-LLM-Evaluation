@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix : <http://llmtest.org/energy/> .

:Appliance rdf:type owl:Class ;
  rdfs:comment "A device that uses energy." .

:SmartAppliance rdf:type owl:Class ;
  rdfs:comment "An appliance that can be controlled remotely." ;
  rdfs:subClassOf :Appliance .

:EnergySource rdf:type owl:Class ;
  rdfs:comment "A source of energy." .

:Electricity rdf:type owl:Class ;
  rdfs:comment "A form of energy generated by the movement of charged particles." ;
  rdfs:subClassOf :EnergySource .

:Gas rdf:type owl:Class ;
  rdfs:comment "A form of energy generated by the combustion of fossil fuels." ;
  rdfs:subClassOf :EnergySource .

:SolarEnergy rdf:type owl:Class ;
  rdfs:comment "A form of energy generated by the sun." ;
  rdfs:subClassOf :EnergySource .

:WindEnergy rdf:type owl:Class ;
  rdfs:comment "A form of energy generated by the wind." ;
  rdfs:subClassOf :EnergySource .

:HydroEnergy rdf:type owl:Class ;
  rdfs:comment "A form of energy generated by the movement of water." ;
  rdfs:subClassOf :EnergySource .

:ApplianceType rdf:type owl:Class ;
  rdfs:comment "A category of appliances." .

:Refrigerator rdf:type owl:Class ;
  rdfs:comment "A device that keeps food and drinks cool." ;
  rdfs:subClassOf :Appliance .

:AirConditioner rdf:type owl:Class ;
  rdfs:comment "A device that cools the air." ;
  rdfs:subClassOf :Appliance .

:WashingMachine rdf:type owl:Class ;
  rdfs:comment "A device that cleans clothes." ;
  rdfs:subClassOf :Appliance .

:SmartRefrigerator rdf:type owl:Class ;
  rdfs:comment "A refrigerator that can be controlled remotely." ;
  rdfs:subClassOf :SmartAppliance .

:SmartAirConditioner rdf:type owl:Class ;
  rdfs:comment "An air conditioner that can be controlled remotely." ;
  rdfs:subClassOf :SmartAppliance .

:SmartWashingMachine rdf:type owl:Class ;
  rdfs:comment "A washing machine that can be controlled remotely." ;
  rdfs:subClassOf :SmartAppliance .

:EnergyUsage rdf:type owl:Class ;
  rdfs:comment "The amount of energy used by an appliance." .

:EnergyConsumption rdf:type owl:Class ;
  rdfs:comment "The rate at which an appliance uses energy." .

:ApplianceStatus rdf:type owl:Class ;
  rdfs:comment "The current state of an appliance." .

:ApplianceControl rdf:type owl:Class ;
  rdfs:comment "The ability to control an appliance remotely." .

:EnergyEfficiency rdf:type owl:Class ;
  rdfs:comment "The measure of how efficiently an appliance uses energy." .

:ApplianceMaintenance rdf:type owl:Class ;
  rdfs:comment "The process of maintaining an appliance." .

:ApplianceRepair rdf:type owl:Class ;
  rdfs:comment "The process of fixing an appliance." .

:ApplianceUpgrade rdf:type owl:Class ;
  rdfs:comment "The process of upgrading an appliance." .

:ApplianceWarranty rdf:type owl:Class ;
  rdfs:comment "The guarantee provided by a manufacturer for an appliance." .

:ApplianceModel rdf:type owl:Class ;
  rdfs:comment "A specific version of an appliance." .

:ApplianceBrand rdf:type owl:Class ;
  rdfs:comment "The company that manufactures an appliance." .

:AppliancePrice rdf:type owl:Class ;
  rdfs:comment "The cost of an appliance." .

:ApplianceRating rdf:type owl:Class ;
  rdfs:comment "The rating given to an appliance based on its performance." .

:ApplianceReview rdf:type owl:Class ;
  rdfs:comment "A review of an appliance by a user." .

:ApplianceRatingValue rdf:type owl:DataProperty ;
  rdfs:comment "The value of an appliance's rating." ;
  rdfs:domain :ApplianceRating ;
  rdfs:range xsd:decimal .

:AppliancePriceValue rdf:type owl:DataProperty ;
  rdfs:comment "The value of an appliance's price." ;
  rdfs:domain :AppliancePrice ;
  rdfs:range xsd:decimal .

:ApplianceEnergyUsage rdf:type owl:DataProperty ;
  rdfs:comment "The amount of energy used by an appliance." ;
  rdfs:domain :Appliance ;
  rdfs:range xsd:decimal .

:ApplianceEnergyConsumption rdf:type owl:DataProperty ;
  rdfs:comment "The rate at which an appliance uses energy." ;
  rdfs:domain :Appliance ;
  rdfs:range xsd:decimal .

:ApplianceStatusValue rdf:type owl:DataProperty ;
  rdfs:comment "The current state of an appliance." ;
  rdfs:domain :ApplianceStatus ;
  rdfs:range xsd:string .

:ApplianceControlValue rdf:type owl:DataProperty ;
  rdfs:comment "The ability to control an appliance remotely." ;
  rdfs:domain :ApplianceControl ;
  rdfs:range xsd:boolean .

:ApplianceEnergyEfficiency rdf:type owl:DataProperty ;
  rdfs:comment "The measure of how efficiently an appliance uses energy." ;
  rdfs:domain :Appliance ;
  rdfs:range xsd:decimal .

:ApplianceMaintenanceValue rdf:type owl:DataProperty ;
  rdfs:comment "The process of maintaining an appliance." ;
  rdfs:domain :ApplianceMaintenance ;
  rdfs:range xsd:string .

:ApplianceRepairValue rdf:type owl:DataProperty ;
  rdfs:comment "The process of fixing an appliance." ;
  rdfs:domain :ApplianceRepair ;
  rdfs:range xsd:string .

:ApplianceUpgradeValue rdf:type owl:DataProperty ;
  rdfs:comment "The process of upgrading an appliance." ;
  rdfs:domain :ApplianceUpgrade ;
  rdfs:range xsd:string .

:ApplianceWarrantyValue rdf:type owl:DataProperty ;
  rdfs:comment "The guarantee provided by a manufacturer for an appliance." ;
  rdfs:domain :ApplianceWarranty ;
  rdfs:range xsd:string .

:ApplianceModelValue rdf:type owl:DataProperty ;
  rdfs:comment "A specific version of an appliance." ;
  rdfs:domain :ApplianceModel ;
  rdfs:range xsd:string .

:ApplianceBrandValue rdf:type owl:DataProperty ;
  rdfs:comment "The company that manufactures an appliance." ;
  rdfs:domain :ApplianceBrand ;
  rdfs:range xsd:string .

:ApplianceReviewValue rdf:type owl:DataProperty ;
  rdfs:comment "A review of an appliance by a user." ;
  rdfs:domain :ApplianceReview ;
  rdfs:range xsd:string .

:ApplianceControlledBy rdf:type owl:ObjectProperty ;
  rdfs:comment "The device that controls an appliance." ;
  rdfs:domain :SmartAppliance ;
  rdfs:range :Appliance .

:ApplianceUsesEnergyFrom rdf:type owl:ObjectProperty ;
  rdfs:comment "The source of energy used by an appliance." ;
  rdfs:domain :Appliance ;
  rdfs:range :EnergySource .

:ApplianceIsMaintainedBy rdf:type owl:ObjectProperty ;
  rdfs:comment "The person or organization that maintains an appliance." ;
  rdfs:domain :Appliance ;
  rdfs:range :Person .

:ApplianceIsReviewedBy rdf:type owl:ObjectProperty ;
  rdfs:comment "The person who reviewed an appliance." ;
  rdfs:domain :Appliance ;
  rdfs:range :Person .

:ApplianceIsRatedBy rdf:type owl:ObjectProperty ;
  rdfs:comment "The person or organization that rated an appliance." ;
  rdfs:domain :Appliance ;
  rdfs:range :Person .

:ApplianceIsUpgradedBy rdf:type owl:ObjectProperty ;
  rdfs:comment "The person or organization that upgraded an appliance." ;
  rdfs:domain :Appliance ;
  rdfs:range :Person .

:ApplianceIsWarrantiedBy rdf:type owl:ObjectProperty ;
  rdfs:comment "The person or organization that provides a warranty for an appliance." ;
  rdfs:domain :Appliance ;
  rdfs:range :Person .