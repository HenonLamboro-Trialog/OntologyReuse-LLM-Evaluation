@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix :     <http://llmtest.org/energy/> .

#################################################################
# Classes
#################################################################

:Device a owl:Class ;
    rdfs:comment "A general device in the smart appliance energy domain." .

:SmartAppliance a owl:Class ;
    rdfs:subClassOf :Device ;
    rdfs:comment "A device with smart capabilities for energy management." .

:EnergyMeter a owl:Class ;
    rdfs:subClassOf :Device ;
    rdfs:comment "A device that measures energy consumption or production." .

:Sensor a owl:Class ;
    rdfs:subClassOf :Device ;
    rdfs:comment "A device that senses environmental or operational parameters." .

:Actuator a owl:Class ;
    rdfs:subClassOf :Device ;
    rdfs:comment "A device that acts upon commands to control appliances." .

:HomeAppliance a owl:Class ;
    rdfs:subClassOf :SmartAppliance ;
    rdfs:comment "A smart appliance used in residential settings." .

:IndustrialAppliance a owl:Class ;
    rdfs:subClassOf :SmartAppliance ;
    rdfs:comment "A smart appliance used in industrial environments." .

:LightingAppliance a owl:Class ;
    rdfs:subClassOf :HomeAppliance ;
    rdfs:comment "A home appliance used for lighting purposes." .

:HVACAppliance a owl:Class ;
    rdfs:subClassOf :HomeAppliance ;
    rdfs:comment "A home appliance for heating, ventilation, and air conditioning." .

:KitchenAppliance a owl:Class ;
    rdfs:subClassOf :HomeAppliance ;
    rdfs:comment "A home appliance used in the kitchen." .

:Refrigerator a owl:Class ;
    rdfs:subClassOf :KitchenAppliance ;
    rdfs:comment "A kitchen appliance for cooling and preserving food." .

:WashingMachine a owl:Class ;
    rdfs:subClassOf :KitchenAppliance ;
    rdfs:comment "A kitchen appliance for washing clothes." .

:Oven a owl:Class ;
    rdfs:subClassOf :KitchenAppliance ;
    rdfs:comment "A kitchen appliance for baking or cooking food." .

:SmartPlug a owl:Class ;
    rdfs:subClassOf :SmartAppliance ;
    rdfs:comment "A smart device that controls power supply to appliances." .

:SmartThermostat a owl:Class ;
    rdfs:subClassOf :HVACAppliance ;
    rdfs:comment "A smart device for controlling temperature settings." .

:SmartLight a owl:Class ;
    rdfs:subClassOf :LightingAppliance ;
    rdfs:comment "A smart lighting device with adjustable settings." .

:MotionSensor a owl:Class ;
    rdfs:subClassOf :Sensor ;
    rdfs:comment "A sensor that detects motion." .

:TemperatureSensor a owl:Class ;
    rdfs:subClassOf :Sensor ;
    rdfs:comment "A sensor that measures temperature." .

:HumiditySensor a owl:Class ;
    rdfs:subClassOf :Sensor ;
    rdfs:comment "A sensor that measures humidity." .

:EnergyConsumptionProfile a owl:Class ;
    rdfs:comment "A profile describing energy consumption patterns." .

:EnergyProductionProfile a owl:Class ;
    rdfs:comment "A profile describing energy production patterns." .

:User a owl:Class ;
    rdfs:comment "A person or entity interacting with smart appliances." .

:Room a owl:Class ;
    rdfs:comment "A physical room where appliances are located." .

:Building a owl:Class ;
    rdfs:comment "A building containing rooms and appliances." .

:Schedule a owl:Class ;
    rdfs:comment "A schedule for appliance operation." .

:EnergySource a owl:Class ;
    rdfs:comment "A source of energy, such as grid or solar." .

:Grid a owl:Class ;
    rdfs:subClassOf :EnergySource ;
    rdfs:comment "The main electricity grid." .

:SolarPanel a owl:Class ;
    rdfs:subClassOf :EnergySource ;
    rdfs:comment "A solar panel as an energy source." .

:BatteryStorage a owl:Class ;
    rdfs:subClassOf :EnergySource ;
    rdfs:comment "A battery used for energy storage." .

:Alert a owl:Class ;
    rdfs:comment "An alert generated by a device or system." .

:MaintenanceEvent a owl:Class ;
    rdfs:comment "An event indicating maintenance activity." .

#################################################################
# Object Properties
#################################################################

:locatedIn a owl:ObjectProperty ;
    rdfs:domain :Device ;
    rdfs:range :Room ;
    rdfs:comment "Indicates the room where a device is located." .

:hasSensor a owl:ObjectProperty ;
    rdfs:domain :SmartAppliance ;
    rdfs:range :Sensor ;
    rdfs:comment "Associates a smart appliance with its sensors." .

:controlledBy a owl:ObjectProperty ;
    rdfs:domain :SmartAppliance ;
    rdfs:range :Actuator ;
    rdfs:comment "Indicates which actuator controls the appliance." .

:monitors a owl:ObjectProperty ;
    rdfs:domain :Sensor ;
    rdfs:range :Device ;
    rdfs:comment "Indicates which device is monitored by a sensor." .

:hasEnergyProfile a owl:ObjectProperty ;
    rdfs:domain :Device ;
    rdfs:range :EnergyConsumptionProfile ;
    rdfs:comment "Links a device to its energy consumption profile." .

:connectedTo a owl:ObjectProperty ;
    rdfs:domain :Device ;
    rdfs:range :EnergySource ;
    rdfs:comment "Indicates the energy source a device is connected to." .

:belongsToUser a owl:ObjectProperty ;
    rdfs:domain :Device ;
    rdfs:range :User ;
    rdfs:comment "Indicates the user who owns or operates the device." .

:hasSchedule a owl:ObjectProperty ;
    rdfs:domain :SmartAppliance ;
    rdfs:range :Schedule ;
    rdfs:comment "Associates a smart appliance with its operation schedule." .

#################################################################
# Datatype Properties
#################################################################

:powerRating a owl:DatatypeProperty ;
    rdfs:domain :Device ;
    rdfs:range xsd:float ;
    rdfs:comment "The power rating of a device in watts." .

:serialNumber a owl:DatatypeProperty ;
    rdfs:domain :Device ;
    rdfs:range xsd:string ;
    rdfs:comment "The serial number of a device." .

:status a owl:DatatypeProperty ;
    rdfs:domain :Device ;
    rdfs:range xsd:string ;
    rdfs:comment "The operational status of a device (e.g., on, off, standby)." .

:energyConsumption a owl:DatatypeProperty ;
    rdfs:domain :EnergyConsumptionProfile ;
    rdfs:range xsd:float ;
    rdfs:comment "The amount of energy consumed in kWh." .

:timestamp a owl:DatatypeProperty ;
    rdfs:domain :Alert ;
    rdfs:range xsd:dateTime ;
    rdfs:comment "The time when an alert was generated." .
