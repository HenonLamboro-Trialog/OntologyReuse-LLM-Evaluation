@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:    <http://www.w3.org/2002/07/owl#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix iot:    <http://purl.oclc.org/NET/UNIS/fiware/iot-lite#> .
@prefix fiesta: <http://purl.oclc.org/NET/FIESTA-IOT#> .
@prefix iotb:   <http://example.org/iot-testbed#> .

#################################################################
# Ontology: IoT Testbed Ontology
#################################################################

iotb:IoTTestbed a owl:Class ;
    rdfs:label "IoT Testbed" ;
    rdfs:comment "A controlled environment for testing IoT devices, networks, and applications." .

iotb:TestbedNode a owl:Class ;
    rdfs:subClassOf fiesta:Node ;
    rdfs:label "Testbed Node" ;
    rdfs:comment "A physical or virtual node within an IoT testbed." .

iotb:TestbedDevice a owl:Class ;
    rdfs:subClassOf iot:Device ;
    rdfs:label "Testbed Device" ;
    rdfs:comment "An IoT device deployed in a testbed." .

iotb:TestbedService a owl:Class ;
    rdfs:subClassOf fiesta:Service ;
    rdfs:label "Testbed Service" ;
    rdfs:comment "A service provided within the IoT testbed." .

iotb:TestbedExperiment a owl:Class ;
    rdfs:label "Testbed Experiment" ;
    rdfs:comment "An experiment conducted within the IoT testbed." .

iotb:TestbedUser a owl:Class ;
    rdfs:subClassOf fiesta:User ;
    rdfs:label "Testbed User" ;
    rdfs:comment "A user interacting with the IoT testbed." .

iotb:TestbedDataset a owl:Class ;
    rdfs:subClassOf fiesta:Dataset ;
    rdfs:label "Testbed Dataset" ;
    rdfs:comment "A dataset generated or used in the IoT testbed." .

#################################################################
# Object Properties
#################################################################

iotb:hasNode a owl:ObjectProperty ;
    rdfs:domain iotb:IoTTestbed ;
    rdfs:range iotb:TestbedNode ;
    rdfs:label "has node" ;
    rdfs:comment "Associates an IoT testbed with its nodes." .

iotb:hasDevice a owl:ObjectProperty ;
    rdfs:domain iotb:TestbedNode ;
    rdfs:range iotb:TestbedDevice ;
    rdfs:label "has device" ;
    rdfs:comment "Associates a testbed node with its devices." .

iotb:providesService a owl:ObjectProperty ;
    rdfs:domain iotb:TestbedDevice ;
    rdfs:range iotb:TestbedService ;
    rdfs:label "provides service" ;
    rdfs:comment "Indicates a device provides a service." .

iotb:hasExperiment a owl:ObjectProperty ;
    rdfs:domain iotb:IoTTestbed ;
    rdfs:range iotb:TestbedExperiment ;
    rdfs:label "has experiment" ;
    rdfs:comment "Associates an IoT testbed with its experiments." .

iotb:performedBy a owl:ObjectProperty ;
    rdfs:domain iotb:TestbedExperiment ;
    rdfs:range iotb:TestbedUser ;
    rdfs:label "performed by" ;
    rdfs:comment "Indicates the user who performed the experiment." .

iotb:usesDataset a owl:ObjectProperty ;
    rdfs:domain iotb:TestbedExperiment ;
    rdfs:range iotb:TestbedDataset ;
    rdfs:label "uses dataset" ;
    rdfs:comment "Indicates the dataset used in an experiment." .

iotb:generatesDataset a owl:ObjectProperty ;
    rdfs:domain iotb:TestbedExperiment ;
    rdfs:range iotb:TestbedDataset ;
    rdfs:label "generates dataset" ;
    rdfs:comment "Indicates the dataset generated by an experiment." .

#################################################################
# Data Properties
#################################################################

iotb:testbedName a owl:DatatypeProperty ;
    rdfs:domain iotb:IoTTestbed ;
    rdfs:range xsd:string ;
    rdfs:label "testbed name" .

iotb:location a owl:DatatypeProperty ;
    rdfs:domain iotb:TestbedNode ;
    rdfs:range xsd:string ;
    rdfs:label "location" ;
    rdfs:comment "Location of the testbed node." .

iotb:experimentStartTime a owl:DatatypeProperty ;
    rdfs:domain iotb:TestbedExperiment ;
    rdfs:range xsd:dateTime ;
    rdfs:label "experiment start time" .

iotb:experimentEndTime a owl:DatatypeProperty ;
    rdfs:domain iotb:TestbedExperiment ;
    rdfs:range xsd:dateTime ;
    rdfs:label "experiment end time" .

iotb:datasetFormat a owl:DatatypeProperty ;
    rdfs:domain iotb:TestbedDataset ;
    rdfs:range xsd:string ;
    rdfs:label "dataset format" ;
    rdfs:comment "Format of the dataset (e.g., CSV, JSON)." .

#################################################################
# Alignment with Reused Ontologies
#################################################################

# fiesta:Node, fiesta:Service, fiesta:User, fiesta:Dataset are reused from FIESTA-IOT ontology
# iot:Device is reused from IoT-Lite ontology

#################################################################
# Example Individual (optional)
#################################################################

# iotb:Testbed1 a iotb:IoTTestbed ;
#     iotb:testbedName "SmartLab Testbed" ;
#     iotb:hasNode iotb:Node1 .

# iotb:Node1 a iotb:TestbedNode ;
#     iotb:location "Building A, Floor 2" ;
#     iotb:hasDevice iotb:Device1 .

# iotb:Device1 a iotb:TestbedDevice ;
#     iotb:providesService iotb:Service1 .

# iotb:Service1 a iotb:TestbedService .

# iotb:Experiment1 a iotb:TestbedExperiment ;
#     iotb:experimentStartTime "2024-06-01T10:00:00"^^xsd:dateTime ;
#     iotb:experimentEndTime "2024-06-01T12:00:00"^^xsd:dateTime ;
#     iotb:performedBy iotb:User1 ;
#     iotb:usesDataset iotb:Dataset1 ;
#     iotb:generatesDataset iotb:Dataset2 .

# iotb:User1 a iotb:TestbedUser .

# iotb:Dataset1 a iotb:TestbedDataset ;
#     iotb:datasetFormat "CSV" .

# iotb:Dataset2 a iotb:TestbedDataset ;
#     iotb:datasetFormat "JSON" .
# ```
# **Notes:**
# - Classes and properties from [FIESTA-IOT ontology](https://purl.oclc.org/NET/FIESTA-IOT#) and [IoT-Lite ontology](https://purl.oclc.org/NET/UNIS/fiware/iot-lite#) are reused and mapped.
# - New classes and properties are introduced only where necessary for the IoT testbed domain.
# - The ontology is modular and extensible for further refinement.